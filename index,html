<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Recorrido 7 Templos - RUU 2025</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');

        :root {
            --accent-gold: #f59e0b;
            --glass-bg: rgba(15, 23, 42, 0.9);
            --glass-border: rgba(255, 255, 255, 0.1);
            --card-glass: rgba(7, 10, 20, 0.95);
        }

        body, html {
            margin: 0; padding: 0; height: 100%;
            background-color: #020617;
            color: #f8fafc;
            font-family: 'Plus Jakarta Sans', sans-serif;
            overflow: hidden;
        }

        #map {
            position: absolute; top: 0; bottom: 0; width: 100%;
            z-index: 1;
            filter: saturate(1.1) brightness(0.7) contrast(1.1);
        }

        .church-marker-ui { display: flex; align-items: center; justify-content: center; }

        .icon-wrapper {
            width: 44px; height: 44px;
            background: var(--glass-bg);
            border: 2px solid var(--accent-gold);
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            backdrop-filter: blur(8px);
            box-shadow: 0 0 20px rgba(245, 158, 11, 0.2);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .icon-wrapper i { color: var(--accent-gold); font-size: 18px; }

        .icon-wrapper.visited {
            background: var(--accent-gold);
            transform: scale(1.1);
            border-color: #fff;
            box-shadow: 0 0 25px rgba(245, 158, 11, 0.5);
        }

        .icon-wrapper.visited i { color: #000; }

        .interface-layer {
            position: absolute; inset: 0;
            pointer-events: none; z-index: 100;
            display: flex; flex-direction: column;
            justify-content: space-between; padding: 20px;
        }

        .interface-layer > * { pointer-events: auto; }

        .floating-header {
            background: var(--glass-bg);
            backdrop-filter: blur(15px);
            border: 1px solid var(--glass-border);
            padding: 18px;
            border-radius: 24px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
            max-width: 400px;
        }

        #info-card {
            background: var(--card-glass);
            backdrop-filter: blur(30px);
            border: 1px solid var(--glass-border);
            border-radius: 32px 32px 0 0;
            padding: 24px;
            padding-bottom: 40px;
            color: #f8fafc;
            transform: translateY(120%);
            transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
            box-shadow: 0 -15px 50px rgba(0,0,0,0.7);
            position: fixed; bottom: 0; left: 0; right: 0;
            z-index: 1000;
        }

        #info-card.active { transform: translateY(0); }

        .btn-action {
            background: var(--accent-gold);
            color: #000; padding: 14px;
            border-radius: 18px; font-weight: 800;
            display: flex; align-items: center; justify-content: center;
            gap: 10px; transition: all 0.3s;
            text-transform: uppercase; font-size: 13px;
        }

        .btn-action:active { transform: scale(0.96); }

        .pill-category {
            background: rgba(245, 158, 11, 0.12);
            color: var(--accent-gold);
            padding: 5px 12px; border-radius: 100px;
            font-size: 9px; font-weight: 800;
            text-transform: uppercase; letter-spacing: 1px;
            border: 1px solid rgba(245, 158, 11, 0.2);
        }

        .progress-bar {
            height: 100%;
            background: linear-gradient(90deg, #f59e0b, #fbbf24);
            width: 0%; transition: width 0.8s ease;
        }

        .reflection-box {
            background: rgba(255, 255, 255, 0.03);
            border-left: 3px solid var(--accent-gold);
            padding: 12px;
            margin: 15px 0;
            font-style: italic;
            font-size: 13px;
            color: #cbd5e1;
        }

        .btn-share {
            background: #25d366;
            color: white;
            padding: 10px 15px;
            border-radius: 14px;
            font-size: 11px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
        }
    </style>
</head>
<body>

    <div id="map"></div>

    <div class="interface-layer">
        <!-- Cabecera Superior -->
        <div class="floating-header">
            <div class="flex justify-between items-start mb-3">
                <div>
                    <h2 class="font-serif italic text-2xl text-white">Siete Templos</h2>
                    <p class="text-[10px] font-bold text-amber-500 uppercase tracking-[0.2em]">RUU • FE Y TRADICIÓN</p>
                </div>
                <div class="flex flex-col items-end">
                    <div class="flex items-baseline gap-1">
                        <span id="stat-counter" class="text-3xl font-black text-white">0</span>
                        <span class="text-xs font-bold text-slate-500">/ 7</span>
                    </div>
                    <button id="share-progress" onclick="shareOnWhatsApp()" class="hidden text-[9px] bg-green-600/20 text-green-400 px-2 py-1 rounded-md mt-1 border border-green-600/30">
                        <i class="fab fa-whatsapp"></i> COMPARTIR
                    </button>
                </div>
            </div>
            
            <div class="h-1.5 bg-white/5 rounded-full overflow-hidden">
                <div id="progress-bar" class="progress-bar"></div>
            </div>

            <button onclick="openFullRoute()" class="w-full mt-4 py-2.5 rounded-xl border border-amber-500/30 bg-amber-500/5 text-amber-500 text-[10px] font-black uppercase tracking-widest flex items-center justify-center gap-2 transition-all hover:bg-amber-500 hover:text-black">
                <i class="fas fa-route"></i> INICIAR RUTA COMPLETA GPS
            </button>
        </div>

        <!-- Controles Flotantes Derecha -->
        <div class="flex flex-col items-end gap-3 mb-4">
            <button onclick="locateUser()" class="w-12 h-12 bg-slate-900/80 backdrop-blur-xl text-white border border-white/10 rounded-2xl shadow-xl flex items-center justify-center text-lg active:scale-90">
                <i class="fas fa-location-arrow"></i>
            </button>
        </div>

        <!-- Tarjeta de Detalle (Se activa al tocar un marcador) -->
        <div id="info-card">
            <div class="w-10 h-1 bg-white/20 rounded-full mx-auto mb-5"></div>
            
            <div class="flex justify-between items-start mb-2">
                <div>
                    <span id="t-pill" class="pill-category">Estación 1</span>
                    <h3 id="t-name" class="text-2xl font-extrabold text-white mt-2 leading-tight">Nombre</h3>
                    <p id="t-address" class="text-amber-500 text-[11px] font-bold mt-1 uppercase tracking-wider flex items-center gap-1">
                        <i class="fas fa-map-pin"></i> <span>Dirección</span>
                    </p>
                </div>
                <button onclick="closeCard()" class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center text-white/40">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div id="t-reflection" class="reflection-box">
                "Caminamos en oración recordando el sacrificio..."
            </div>

            <p id="t-desc" class="text-slate-400 text-xs leading-relaxed mb-6">Descripción.</p>

            <div class="grid grid-cols-2 gap-3">
                <button id="btn-nav" class="btn-action w-full">
                    <i class="fas fa-directions"></i> CÓMO LLEGAR
                </button>
                <button onclick="shareStation()" class="bg-white/5 border border-white/10 rounded-18 font-bold text-xs flex items-center justify-center gap-2 text-white py-3 rounded-xl">
                    <i class="fas fa-share-alt"></i> ENVIAR SITIO
                </button>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/leaflet-ant-path@1.3.0/dist/leaflet-ant-path.min.js"></script>
    
    <script>
        const routeData = {
            start: { lat: 4.5794, lng: -74.1145, name: "Parque Granjas de San Pablo" },
            locations: [
                { id: 1, name: "Parroquia San Pablo", address: "Carrera 12f #33 sur", lat: 4.5785, lng: -74.1158, reflection: "Jesús en el Huerto de los Olivos: Meditemos sobre la angustia y la entrega de Cristo.", info: "Un epicentro de fe en el barrio San Pablo, donde la arquitectura se une con la devoción popular." },
                { id: 2, name: "Parroquia El Pesebre", address: "Carrera 13 #36 sur", lat: 4.5742, lng: -74.1185, reflection: "Jesús ante Anás: Reflexionemos sobre el juicio injusto y la humildad ante la ofensa.", info: "Lugar emblemático que guarda las tradiciones más profundas de nuestra localidad." },
                { id: 3, name: "Parroquia Sta. María de Las Colinas", address: "Carrera 14 #39 sur", lat: 4.5715, lng: -74.1205, reflection: "Jesús ante Caifás: La perseverancia en la verdad a pesar de las falsas acusaciones.", info: "Un santuario de paz con una vista que invita al silencio y la reflexión espiritual." },
                { id: 4, name: "Parroquia S. Juan Bautista de La Salle", address: "Calle 42 sur #15", lat: 4.5685, lng: -74.1235, reflection: "Jesús ante Pilato: El valor de la justicia frente a la presión del mundo.", info: "Referente arquitectónico y espiritual para todos los habitantes del sector." },
                { id: 5, name: "Parroquia San Juan Pablo II", address: "Carrera 16 #45 sur", lat: 4.5655, lng: -74.1265, reflection: "Jesús ante Herodes: La dignidad del silencio ante la burla y la curiosidad vana.", info: "Templo moderno dedicado al Papa que recorrió el mundo, símbolo de esperanza." },
                { id: 6, name: "Parroquia Ntra. Sra. del Camino", address: "Calle 49 sur #17", lat: 4.5615, lng: -74.1295, reflection: "Jesús de nuevo ante Pilato: La entrega total por amor a la humanidad.", info: "La casa que acoge a los peregrinos en su caminar por las lomas de Rafael Uribe Uribe." },
                { id: 7, name: "Parroquia de La Resurrección", address: "Calle 52 sur #19", lat: 4.5585, lng: -74.1335, reflection: "Jesús en el Sepulcro: La esperanza de la nueva vida que vence a la muerte.", info: "Punto final de nuestro recorrido, donde celebramos la vida y la renovación de la fe." }
            ]
        };

        let map, currentLoc;
        let visited = new Set();

        function init() {
            map = L.map('map', { zoomControl: false, attributionControl: false }).setView([routeData.start.lat, routeData.start.lng], 15);
            
            // Estilo de mapa oscuro premium de CartoDB
            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png').addTo(map);

            const points = [[routeData.start.lat, routeData.start.lng]];
            
            // Punto de Inicio
            L.marker([routeData.start.lat, routeData.start.lng], {
                icon: L.divIcon({ className: '', html: '<div class="w-4 h-4 bg-emerald-500 border-2 border-white rounded-full shadow-[0_0_15px_#10b981]"></div>' })
            }).addTo(map);

            // Marcadores de Iglesias
            routeData.locations.forEach(loc => {
                points.push([loc.lat, loc.lng]);
                const icon = L.divIcon({
                    className: 'church-marker-ui',
                    html: `<div class="icon-wrapper" id="marker-${loc.id}"><i class="fas fa-church"></i></div>`,
                    iconSize: [44, 44]
                });
                L.marker([loc.lat, loc.lng], { icon }).addTo(map).on('click', () => openDetails(loc));
            });

            // Línea de ruta con efecto "ant-path"
            L.polyline.antPath(points, { delay: 2000, weight: 4, color: '#f59e0b', pulseColor: '#ffffff', opacity: 0.5 }).addTo(map);
        }

        function openDetails(loc) {
            currentLoc = loc;
            document.getElementById('t-pill').innerText = `Estación ${loc.id} de 7`;
            document.getElementById('t-name').innerText = loc.name;
            document.getElementById('t-address').querySelector('span').innerText = loc.address;
            document.getElementById('t-reflection').innerText = `"${loc.reflection}"`;
            document.getElementById('t-desc').innerText = loc.info;
            
            document.getElementById('btn-nav').onclick = () => {
                window.open(`https://www.google.com/maps/dir/?api=1&destination=${loc.lat},${loc.lng}&travelmode=walking`, '_blank');
            };

            document.getElementById('info-card').classList.add('active');
            map.flyTo([loc.lat - 0.0015, loc.lng], 17);
            markVisited(loc.id);
        }

        function markVisited(id) {
            if (!visited.has(id)) {
                visited.add(id);
                const el = document.getElementById(`marker-${id}`);
                if (el) el.classList.add('visited');
                updateProgress();
            }
        }

        function updateProgress() {
            const count = visited.size;
            document.getElementById('stat-counter').innerText = count;
            document.getElementById('progress-bar').style.width = (count / 7 * 100) + '%';
            if(count > 0) document.getElementById('share-progress').classList.remove('hidden');
        }

        function closeCard() {
            document.getElementById('info-card').classList.remove('active');
        }

        function locateUser() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(p => {
                    map.flyTo([p.coords.latitude, p.coords.longitude], 17);
                });
            }
        }

        function openFullRoute() {
            const origin = `${routeData.start.lat},${routeData.start.lng}`;
            const destination = `${routeData.locations[6].lat},${routeData.locations[6].lng}`; 
            const waypoints = routeData.locations.slice(0, 6).map(l => `${l.lat},${l.lng}`).join('|');
            const url = `https://www.google.com/maps/dir/?api=1&origin=${origin}&destination=${destination}&waypoints=${waypoints}&travelmode=walking`;
            window.open(url, '_blank');
        }

        function shareOnWhatsApp() {
            const text = `¡Hola! Estoy realizando el recorrido de los 7 Templos en Rafael Uribe Uribe. He visitado ${visited.size} de 7 iglesias. 🙏✨`;
            window.open(`https://wa.me/?text=${encodeURIComponent(text)}`, '_blank');
        }

        function shareStation() {
            if(!currentLoc) return;
            const text = `Te comparto esta parada del recorrido de Semana Santa: ${currentLoc.name} (${currentLoc.address}). ¡Acompáñanos! ⛪`;
            window.open(`https://wa.me/?text=${encodeURIComponent(text)}`, '_blank');
        }

        window.onload = init;
    </script>
</body>
</html>
